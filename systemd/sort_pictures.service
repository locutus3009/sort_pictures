[Unit]
Description=Sort Pictures Service
After=graphical-session.target

[Service]
Type=simple
ExecStart=/home/locutus/apps/bin/sort_pictures --daemonize --path /hdd/locutus/Pictures/Screenshots --path /hdd/locutus/Pictures/Хроника --path "/hdd/locutus/Pictures/Спорт/Кроссфит и ТА"
#ExecStart=/home/locutus/apps/bin/sort_pictures --daemonize --path /home/locutus/dev/sort_pictures/tmp
RestartSec=10
Environment=HOME=%h
WorkingDirectory=%h

[Install]
WantedBy=default.target
